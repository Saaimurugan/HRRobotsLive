import json
import base64
import boto3
import datetime	
import uuid
import re

# AWS Clients
s3 = boto3.client('s3')
dynamodb = boto3.resource('dynamodb')

# Constants
BUCKET_NAME = 'hrrfiles'
TABLE_NAME = 'candidatePhoto'

def lambda_handler(event, context):
    try:
        image_data = event.get('image')
        user_unique_id = event.get('userUniqueID')

        # Extract base64 string from Data URI
        match = re.match(r'data:(image/\w+);base64,(.*)', image_data)
        if not match:
            raise ValueError('Invalid image data format')

        content_type = match.group(1)  # e.g., image/jpeg
        image_base64 = match.group(2)

        # Decode the base64 string
        image_bytes = base64.b64decode(image_base64)
        image_id = str(uuid.uuid4())

        # Determine file extension from content type
        extension = content_type.split("/")[1]  # e.g., 'jpeg'
        filename = f"face_capture_{uuid.uuid4().hex}.{extension}"
        s3_path = f"https://{BUCKET_NAME}.s3.amazonaws.com/{filename}"
        
        # Upload image to S3
        s3.put_object(Bucket=BUCKET_NAME, Key=filename, Body=image_bytes, ContentType=content_type)
        
        # Save metadata to DynamoDB
        table = dynamodb.Table(TABLE_NAME)
        table.put_item(
            Item={
                'photoID': image_id,
                'testID': user_unique_id,
                'imagePath': s3_path,
                'timestamp': str(datetime.datetime.now())
            }
        )
        
        return {
            'statusCode': 200,
            'body': json.dumps({'message': 'Image uploaded and saved successfully', 'imagePath': s3_path})
        }
    except Exception as e:
        return {
            'statusCode': 500,
            'body': json.dumps({'error': str(e)})
        }
