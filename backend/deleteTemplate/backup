import json
import boto3
from botocore.exceptions import ClientError

def lambda_handler(event, context):
    # Initialize DynamoDB client
    dynamodb = boto3.resource('dynamodb')

    # Reference the 'template' table
    table = dynamodb.Table('template')

    # Retrieve 'templateID' from the event
    JSONData = str(event)
    body = json.loads(JSONData.replace("'",'"'))
    template_id = body["templateIDSelectedForDelete"]

    if not template_id:
        return {
            "statusCode": 400,
            "body": json.dumps({"error": "templateID is required"})
        }

    try:
        JSONData = str(event)
        body = json.loads(JSONData.replace("'",'"'))
        template_id = body["templateIDSelectedForDelete"]

        # Attempt to delete the item
        response = table.delete_item(
            Key={
                'templateID': template_id
            }
        )

        # Check for conditional write success (if necessary)
        return {
            "statusCode": 200,
            "body": json.dumps({"message": f"Template with ID {template_id} deleted successfully."})
        }

    except ClientError as e:
        # Handle any errors from DynamoDB
        return {
            "statusCode": 500,
            "body": json.dumps({"error": str(e)})
        }