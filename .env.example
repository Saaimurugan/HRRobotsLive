# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# API Endpoints
REACT_APP_API_GATEWAY_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/dev

# Google reCAPTCHA
REACT_APP_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Application Settings
REACT_APP_MAX_QUESTIONS_PER_TEMPLATE=60
REACT_APP_MIN_QUESTIONS_PER_TEMPLATE=5
REACT_APP_DEFAULT_TEST_DURATION=60

# Email Configuration (if using custom SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password

# Feature Flags (optional)
REACT_APP_ENABLE_AI_INTERVIEW=true
REACT_APP_ENABLE_VOICE_RECOGNITION=true
REACT_APP_ENABLE_FACE_DETECTION=true

# Database Configuration (for reference - Lambda functions use these)
DYNAMODB_TABLE_USERS=Users
DYNAMODB_TABLE_TEMPLATES=Templates
DYNAMODB_TABLE_TESTS=Tests
DYNAMODB_TABLE_QUESTIONS=Questions
DYNAMODB_TABLE_ANSWERS=Answers

# S3 Buckets (for reference)
S3_BUCKET_PHOTOS=hrrobots-candidate-photos
S3_BUCKET_DOCUMENTS=hrrobots-documents

# Security
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=3600

# Notes:
# 1. Copy this file to .env for local development
# 2. Never commit .env file to version control
# 3. Update these values with your actual credentials
# 4. For production, use AWS Secrets Manager or Parameter Store
